{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Information I Curriculum Plan",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "review_status",
    "stage",
    "subject",
    "locale",
    "scope_version",
    "tracking_issue",
    "source_refs",
    "notes",
    "created_at",
    "updated_at",
    "global_prerequisites",
    "numbering_convention",
    "classroom_route",
    "units"
  ],
  "properties": {
    "id": {"const": "curriculum.info1.v1"},
    "type": {"const": "curriculum"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "review_status": {"const": "needs_human_review"},
    "stage": {"const": "high_school"},
    "subject": {"const": "Information I"},
    "locale": {"const": "ja"},
    "scope_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "tracking_issue": {"type": "integer", "minimum": 1},
    "source_refs": {"$ref": "#/$defs/sourceRefs"},
    "notes": {"$ref": "#/$defs/nonEmptyStringList"},
    "created_at": {"$ref": "#/$defs/date"},
    "updated_at": {"$ref": "#/$defs/date"},
    "global_prerequisites": {"$ref": "#/$defs/nonEmptyStringList"},
    "numbering_convention": {"type": "string", "minLength": 1},
    "classroom_route": {"$ref": "#/$defs/classroomRoute"},
    "units": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/unit"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "date": {"type": "string", "format": "date"},
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "versionedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "objectiveId": {
      "type": "string",
      "pattern": "^obj\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "nonEmptyStringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^src\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}
    },
    "objective": {
      "type": "object",
      "required": ["id", "label", "statement", "expected_evidence"],
      "properties": {
        "id": {"$ref": "#/$defs/objectiveId"},
        "label": {"type": "string", "pattern": "^[A-D][1-9][0-9]*\\.O[1-9][0-9]*$"},
        "statement": {"type": "string", "minLength": 1},
        "expected_evidence": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "criterionRef": {
      "type": "object",
      "required": ["rubric_ref", "criterion_id"],
      "properties": {
        "rubric_ref": {"type": "string", "pattern": "^rubric\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
        "criterion_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"}
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "objective_ref",
        "requirement",
        "status",
        "assessment_item_refs",
        "performance_criterion_refs"
      ],
      "properties": {
        "objective_ref": {"$ref": "#/$defs/objectiveId"},
        "requirement": {"const": "two_items_or_one_item_plus_performance_criterion"},
        "status": {"enum": ["not_started", "partial", "complete"]},
        "assessment_item_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^prob\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}
        },
        "performance_criterion_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/criterionRef"}
        }
      },
      "additionalProperties": false
    },
    "instructionalTime": {
      "type": "object",
      "required": ["class_periods_50_min", "self_study_minutes", "is_multi_session_project"],
      "properties": {
        "class_periods_50_min": {"$ref": "#/$defs/positiveRange"},
        "self_study_minutes": {"$ref": "#/$defs/positiveRange"},
        "is_multi_session_project": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "positiveRange": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "integer", "minimum": 1}
    },
    "classroomRoute": {
      "type": "object",
      "required": [
        "period_minutes",
        "mandatory_periods",
        "recommended_extension_periods",
        "recommended_total_periods",
        "extension_allocations"
      ],
      "properties": {
        "period_minutes": {"const": 50},
        "mandatory_periods": {"const": 65},
        "recommended_extension_periods": {"const": 5},
        "recommended_total_periods": {"const": 70},
        "extension_allocations": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/extensionAllocation"}
        }
      },
      "additionalProperties": false
    },
    "extensionAllocation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "lesson_ref", "periods", "purpose"],
          "properties": {
            "kind": {"const": "lesson"},
            "lesson_ref": {"type": "string", "pattern": "^lesson\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
            "periods": {"const": 1},
            "purpose": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "periods", "purpose"],
          "properties": {
            "kind": {"const": "cumulative"},
            "periods": {"const": 1},
            "purpose": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        }
      ]
    },
    "lesson": {
      "type": "object",
      "required": [
        "order",
        "lesson_id",
        "title",
        "status",
        "learning_objectives",
        "prerequisites",
        "key_concepts",
        "assessment_intent",
        "depends_on",
        "source_refs",
        "instructional_time",
        "assessment_coverage"
      ],
      "properties": {
        "order": {"type": "string", "pattern": "^[A-D][1-9][0-9]*$"},
        "lesson_id": {"type": "string", "pattern": "^lesson\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
        "title": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/status"},
        "learning_objectives": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {"$ref": "#/$defs/objective"}
        },
        "prerequisites": {"$ref": "#/$defs/nonEmptyStringList"},
        "key_concepts": {"$ref": "#/$defs/nonEmptyStringList"},
        "assessment_intent": {"type": "string", "minLength": 1},
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^lesson\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}
        },
        "existing_body_ref": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/sourceRefs"},
        "instructional_time": {"$ref": "#/$defs/instructionalTime"},
        "assessment_coverage": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {"$ref": "#/$defs/coverage"}
        }
      },
      "additionalProperties": false
    },
    "sourceLocator": {
      "type": "object",
      "required": ["normative", "commentary"],
      "properties": {
        "normative": {"type": "string", "minLength": 1},
        "commentary": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "unit": {
      "type": "object",
      "required": ["id", "area", "title", "status", "source_locator", "unit_outcome", "lessons"],
      "properties": {
        "id": {"type": "string", "pattern": "^unit\\.info1\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
        "area": {"type": "string", "pattern": "^mext\\.info1\\.[1-4]$"},
        "title": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/status"},
        "source_locator": {"$ref": "#/$defs/sourceLocator"},
        "unit_outcome": {"type": "string", "minLength": 1},
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/lesson"}
        }
      },
      "additionalProperties": false
    }
  }
}
