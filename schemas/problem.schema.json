{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Problem Record",
  "type": "object",
  "required": [
    "id", "type", "schema_version", "status", "created_at", "updated_at",
    "question", "question_type", "lesson_refs", "objective_refs", "answer_refs", "rubric_refs"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^prob\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "type": {"const": "problem"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "question": {"type": "string", "minLength": 1},
    "question_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "difficulty": {"enum": ["basic", "standard", "advanced"]},
    "lesson_refs": {"$ref": "#/$defs/lessonRefs"},
    "objective_refs": {"$ref": "#/$defs/objectiveRefs"},
    "answer_refs": {"$ref": "#/$defs/answerRefs"},
    "rubric_refs": {"$ref": "#/$defs/rubricRefs"},
    "source_refs": {"$ref": "#/$defs/sourceRefs"},
    "learner_checks": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "common_mistakes": {"$ref": "#/$defs/strings"},
    "stage": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "unit": {"type": "string", "minLength": 1},
    "supersedes": {"$ref": "#/$defs/nullableId"},
    "superseded_by": {"$ref": "#/$defs/nullableIdOrIds"}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["draft", "machine_checked", "human_review_requested", "approved", "published", "deprecated", "superseded"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "lessonRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^lesson\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "objectiveRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^obj\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "answerRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^ans\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "rubricRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^rubric\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "sourceRefs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^src\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "nullableId": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "nullableIdOrIds": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, {"type": "null"}]}
  }
}
