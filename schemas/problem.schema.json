{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Problem Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "created_at",
    "updated_at",
    "question",
    "question_type",
    "lesson_refs",
    "answer_refs",
    "rubric_refs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*\\.v[0-9]+$"
    },
    "type": {
      "const": "problem"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "question_type": {
      "type": "string",
      "minLength": 1
    },
    "lesson_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "answer_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rubric_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
