{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Answer Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "created_at",
    "updated_at",
    "problem_id",
    "canonical_answer",
    "answer_type",
    "review_status",
    "revision"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*\\.v[0-9]+$"
    },
    "type": {
      "const": "answer"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "problem_id": {
      "type": "string"
    },
    "canonical_answer": {
      "type": "string",
      "minLength": 1
    },
    "answer_type": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}
