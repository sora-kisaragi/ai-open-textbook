{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Answer Record",
  "type": "object",
  "required": [
    "id", "type", "schema_version", "status", "created_at", "updated_at",
    "problem_id", "canonical_answer", "answer_type", "review_status", "revision"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^ans\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "type": {"const": "answer"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "problem_id": {"type": "string", "pattern": "^prob\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "canonical_answer": {"type": "string", "minLength": 1},
    "acceptable_answers": {"$ref": "#/$defs/strings"},
    "hints": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "answer_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "explanation": {"type": "string", "minLength": 1},
    "review_status": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "verification_status": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "verification_evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/verificationEvidence"}
    },
    "revision": {"type": "integer", "minimum": 1},
    "rubric_refs": {"$ref": "#/$defs/rubricRefs"},
    "source_refs": {"$ref": "#/$defs/sourceRefs"},
    "valid_from": {"type": "string", "format": "date"},
    "valid_to": {"anyOf": [{"type": "string", "format": "date"}, {"type": "null"}]},
    "supersedes": {"$ref": "#/$defs/nullableId"},
    "superseded_by": {"$ref": "#/$defs/nullableIdOrIds"}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["draft", "machine_checked", "human_review_requested", "approved", "published", "deprecated", "superseded"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "rubricRefs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^rubric\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "sourceRefs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^src\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"}},
    "verificationEvidence": {
      "type": "object",
      "required": ["checked_at", "command", "expected", "method", "result"],
      "properties": {
        "checked_at": {"type": "string", "format": "date"},
        "command": {"type": "string", "minLength": 1},
        "expected": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "result": {"enum": ["passed", "failed", "not_run"]}
      },
      "additionalProperties": false
    },
    "nullableId": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "nullableIdOrIds": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, {"type": "null"}]}
  }
}
