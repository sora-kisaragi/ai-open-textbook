{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "rubric"
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "title": "Rubric Record"
}
