{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rubric Record",
  "type": "object",
  "required": ["id", "type", "schema_version", "status", "created_at", "updated_at", "problem_id", "criteria"],
  "properties": {
    "id": {"type": "string", "pattern": "^rubric\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "type": {"const": "rubric"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "problem_id": {"type": "string", "pattern": "^prob\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/criterion"}
    },
    "review_status": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "supersedes": {"$ref": "#/$defs/nullableId"},
    "superseded_by": {"$ref": "#/$defs/nullableIdOrIds"}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["draft", "machine_checked", "human_review_requested", "approved", "published", "deprecated", "superseded"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "criterion": {
      "type": "object",
      "required": ["id", "description", "points"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
        "description": {"type": "string", "minLength": 1},
        "points": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "nullableId": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "nullableIdOrIds": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, {"type": "null"}]}
  }
}
