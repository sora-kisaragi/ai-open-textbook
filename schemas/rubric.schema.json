{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rubric Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "created_at",
    "updated_at",
    "problem_id",
    "criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*\\.v[0-9]+$"
    },
    "type": {
      "const": "rubric"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "problem_id": {
      "type": "string"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
