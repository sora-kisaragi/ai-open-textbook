{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Revision Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "created_at",
    "updated_at",
    "entity_id",
    "change_type",
    "reason",
    "actor"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rev\\.\\d{8}\\.\\d{4}$"
    },
    "type": {
      "const": "revision"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "entity_id": {
      "type": "string"
    },
    "change_type": {
      "enum": [
        "create",
        "update",
        "supersede",
        "deprecate",
        "review_request",
        "publish"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
