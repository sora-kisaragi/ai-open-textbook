{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson Record",
  "type": "object",
  "required": ["id", "type", "schema_version", "status", "created_at", "updated_at", "title", "body_ref", "learning_objectives"],
  "properties": {
    "id": {"type": "string", "pattern": "^lesson\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "type": {"const": "lesson"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "title": {"type": "string", "minLength": 1},
    "body_ref": {"type": "string", "pattern": "^lessons/.+\\.md$"},
    "learning_objectives": {"$ref": "#/$defs/nonEmptyStrings"},
    "locale": {"type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$"},
    "prerequisites": {"$ref": "#/$defs/strings"},
    "source_refs": {"$ref": "#/$defs/refs"},
    "stage": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "unit": {"type": "string", "minLength": 1},
    "supersedes": {"$ref": "#/$defs/nullableId"},
    "superseded_by": {"$ref": "#/$defs/nullableIdOrIds"}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["draft", "machine_checked", "human_review_requested", "approved", "published", "deprecated", "superseded"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "nonEmptyStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "nullableId": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "nullableIdOrIds": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, {"type": "null"}]}
  }
}
