{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Record",
  "type": "object",
  "required": ["id", "type", "schema_version", "status", "created_at", "updated_at", "title", "source_type", "url"],
  "properties": {
    "id": {"type": "string", "pattern": "^src\\.[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "type": {"const": "source"},
    "schema_version": {"const": "1.0"},
    "status": {"$ref": "#/$defs/status"},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "title": {"type": "string", "minLength": 1},
    "source_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "url": {"type": "string", "format": "uri", "pattern": "^https://"},
    "accessed_at": {"type": "string", "format": "date"},
    "publication_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}(?:-[0-9]{2})?$"},
    "issuer": {"type": "string", "minLength": 1},
    "notes": {"type": "string", "minLength": 1},
    "review_status": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "supersedes": {"$ref": "#/$defs/nullableId"},
    "superseded_by": {"$ref": "#/$defs/nullableIdOrIds"}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["draft", "machine_checked", "human_review_requested", "approved", "published", "deprecated", "superseded"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)*\\.v[1-9][0-9]*$"},
    "nullableId": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "nullableIdOrIds": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, {"type": "null"}]}
  }
}
