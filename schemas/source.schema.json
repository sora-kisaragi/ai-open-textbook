{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "schema_version",
    "status",
    "created_at",
    "updated_at",
    "title",
    "source_type",
    "url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*\\.v[0-9]+$"
    },
    "type": {
      "const": "source"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "draft",
        "machine_checked",
        "human_review_requested",
        "approved",
        "published",
        "deprecated",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
